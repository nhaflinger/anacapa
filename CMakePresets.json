{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ANACAPA_ENABLE_OIDN": "ON"
      }
    },
    {
      "name": "macos-base",
      "hidden": true,
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/Darwin",
      "cacheVariables": {
        "OpenImageDenoise_DIR": "/opt/homebrew/lib/cmake/OpenImageDenoise-2.4.1"
      }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS arm64 (Release)",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      }
    },
    {
      "name": "macos-arm64-usd",
      "displayName": "macOS arm64 + USD (Release)",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "ANACAPA_ENABLE_USD": "ON",
        "ANACAPA_ENABLE_METAL": "ON"
      }
    },
    {
      "name": "macos-arm64-usd-viewer",
      "displayName": "macOS arm64 + USD + viewer (Release)",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "ANACAPA_ENABLE_USD": "ON",
        "ANACAPA_ENABLE_METAL": "ON",
        "ANACAPA_ENABLE_VIEWER": "ON"
      }
    },
    {
      "name": "macos-x86_64",
      "displayName": "macOS x86_64 (Release)",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "x86_64"
      }
    },
    {
      "name": "linux-x86_64",
      "displayName": "Linux x86_64 (Release)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/Linux"
    },
    {
      "name": "linux-x86_64-cuda",
      "displayName": "Linux x86_64 + CUDA (Release)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/Linux",
      "cacheVariables": {
        "ANACAPA_ENABLE_CUDA": "ON",
        "CUDA_ARCH": "86"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos-arm64",
      "configurePreset": "macos-arm64"
    },
    {
      "name": "macos-arm64-usd",
      "configurePreset": "macos-arm64-usd"
    },
    {
      "name": "macos-x86_64",
      "configurePreset": "macos-x86_64"
    },
    {
      "name": "linux-x86_64",
      "configurePreset": "linux-x86_64"
    },
    {
      "name": "linux-x86_64-cuda",
      "configurePreset": "linux-x86_64-cuda"
    }
  ]
}
